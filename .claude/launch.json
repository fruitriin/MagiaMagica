{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "magia-serve",
      "runtimeExecutable": "target/debug/magia",
      "runtimeArgs": [
        "serve",
        "crates/magia-cli/src/serve.rs",
        "--port",
        "4747"
      ],
      "port": 4747,
      "autoPort": false
    },
    {
      "name": "web-dev",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "run",
        "--cwd",
        "web",
        "dev"
      ],
      "port": 5173,
      "autoPort": true
    }
  ]
}
